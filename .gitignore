# ==========================================
# 🐍 Python / Django (Pasta /backend)
# ==========================================

# Arquivos compilados do Python
**/__pycache__/
**/*.py[cod]
**/*$py.class

# Ambientes Virtuais (Virtual Environments)
**/venv/
**/.venv/
**/env/
**/ENV/

# Arquivo de variáveis de ambiente do Django (Onde ficam as chaves do Supabase)
**/backend/.env

# Banco de dados local (caso use sqlite para testes rápidos)
**/*.sqlite3

# Arquivos de log e mídia locais
**/*.log
**/backend/media/
**/backend/staticfiles/


# ==========================================
# 📦 Node / Next.js (Pasta /frontend)
# ==========================================

# Dependências (Pasta gigante do Node)
**/frontend/node_modules/
**/node_modules/

# Builds e artefatos do Next.js
**/frontend/.next/
**/frontend/out/
**/frontend/build/

# Arquivos de variáveis de ambiente do Next.js
**/frontend/.env
**/frontend/.env.local
**/frontend/.env.development.local
**/frontend/.env.test.local
**/frontend/.env.production.local

# Logs do npm/yarn
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*


# ==========================================
# 🖥️ Configurações de Sistema (Geral)
# ==========================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Pastas de configuração de IDEs (opcional, mas recomendado)
.vscode/
.idea/